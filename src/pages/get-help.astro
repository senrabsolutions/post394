---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Get Help • Post 394">
  <div class="container">
    <div class="card"><div class="pad">
      <h1 style="margin:0 0 6px;">Veteran Resources</h1>
      <p class="muted" style="margin:0 0 14px;">
        If you need help navigating benefits, resources, or support services, we’ll point you in the right direction.
      </p>

      <div class="grid" style="grid-template-columns:repeat(2,1fr)">
        <div class="card"><div class="pad">
          <h2>Service Officer</h2>
          <p class="muted">Claims guidance, resources, referrals.</p>
          <ul class="muted">
            <li>Hours: (add)</li>
            <li>Phone: (add)</li>
            <li>Email: (add)</li>
          </ul>
        </div></div>

        <div class="card"><div class="pad">
          <h2>Immediate Needs</h2>
          <p class="muted">If you’re in crisis, use urgent resources immediately.</p>
          <ul class="muted">
            <li>Emergency: 911</li>
            <li>Veterans Crisis Line: 988 then press 1</li>
          </ul>
        </div></div>
      </div>
    </div></div>
  </div>
</BaseLayout>