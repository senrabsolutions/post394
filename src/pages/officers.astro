---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Officers & Contacts • American Legion Post 394">
  <div class="container">
    <div class="card"><div class="pad">
      <h1 style="margin:0 0 6px;">Officers & Contacts</h1>
      <p class="muted" style="margin:0;">
        For general questions, call the Post or use the Contact page. For veteran benefit assistance, contact a Service Officer.
      </p>
    </div></div>

    <div class="section">
      <div class="grid" style="grid-template-columns: 1fr 1fr;">
        <div class="card"><div class="pad">
          <h2 class="h2rule" style="margin:0 0 12px;">Post Officers</h2>
          <div class="twoColList muted">
            <div><strong>Commander</strong><span>(add name)</span></div>
            <div><strong>1st Vice</strong><span>(add name)</span></div>
            <div><strong>2nd Vice</strong><span>(add name)</span></div>
            <div><strong>Adjutant</strong><span>(add name)</span></div>
            <div><strong>Finance</strong><span>(add name)</span></div>
            <div><strong>Chaplain</strong><span>(add name)</span></div>
            <div><strong>Sergeant-at-Arms</strong><span>(add name)</span></div>
            <div><strong>Judge Advocate</strong><span>(add name)</span></div>
          </div>
          <p class="muted" style="margin-top:12px; opacity:.85;">
            (Update as officers change.)
          </p>
        </div></div>

        <div class="card"><div class="pad">
          <h2 class="h2rule" style="margin:0 0 12px;">Service Officers</h2>
          <div class="twoColList muted">
            <div><strong>Service Officer</strong><span>(add name)</span></div>
            <div><strong>Phone</strong><span>(add)</span></div>
            <div><strong>Email</strong><span>(add)</span></div>
            <div><strong>Hours</strong><span>(add day/time)</span></div>
          </div>

          <h2 class="h2rule" style="margin:18px 0 12px;">Sick Call / TAPS</h2>
          <p class="muted" style="margin:0;">
            For Sick Call updates or TAPS notifications, contact the Chaplain:<br />
            <strong>(Chaplain name)</strong> • <strong>(phone)</strong>
          </p>
        </div></div>
      </div>
    </div>
  </div>
</BaseLayout>