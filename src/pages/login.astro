---
import BaseLayout from "../layouts/BaseLayout.astro";

const supabaseUrl = import.meta.env.PUBLIC_SUPABASE_URL;
const supabaseAnonKey = import.meta.env.PUBLIC_SUPABASE_ANON_KEY;
---

<BaseLayout title="Staff Login • American Legion Post 394">
  <div class="container">
    <div class="card">
      <div class="pad" style="max-width:560px; margin:0 auto;">
        <h1 style="margin:0 0 8px;">Staff Login</h1>
        <p class="muted" style="margin:0 0 18px;">
          Authorized Post officers and staff only.
        </p>

        <div
          id="login-box"
          class="form"
          data-supabase-url={supabaseUrl}
          data-supabase-anon-key={supabaseAnonKey}
        >
          <label>
            <span>Email</span>
            <input id="email" name="email" type="email" autocomplete="username" required />
          </label>

          <label>
            <span>Password</span>
            <input id="password" name="password" type="password" autocomplete="current-password" required />
          </label>

          <button id="login-btn" class="btn btn--primary" type="button" style="width:100%;">
            Log In
          </button>

          <p id="login-message" class="muted" style="margin-top:12px;"></p>
        </div>
      </div>
    </div>
  </div>

  <script type="module" src="/login.js"></script>
</BaseLayout>