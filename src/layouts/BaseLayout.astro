---
import ALEmblem from "../assets/ALEmblem.png";

const title = Astro.props.title ?? "American Legion Post 394";
const description =
  Astro.props.description ?? "Supporting Veterans. Serving Palm Bay. Building Community.";
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <link rel="stylesheet" href="/styles.css" />
  </head>

  <body>
    <header class="header">
      <div class="container header__inner">
        <a class="brand" href="/">
          <img class="brand__logo" src={ALEmblem.src} alt="American Legion emblem" />
          <span class="brand__text">
            <strong>American Legion Post 394</strong>
            <span>Palm Bay, Florida</span>
          </span>
        </a>

        <nav class="nav" aria-label="Primary">
          <a href="/">Home</a>
          <a href="/events">Events</a>
          <a href="/news">News</a>
          <a href="/resources">Resources</a>
          <a href="/documents">Documents</a>
          <a href="/officers">Officers</a>
          <a href="/hall">Hall Rental</a>
          <a href="/join">Join</a>
          <a class="btn btn--small" href="/contact">Contact</a>
        </nav>
      </div>
    </header>

    <main class="main">
      <slot />
    </main>

    <footer class="footer">
      <div class="container footer__grid">
        <div>
          <h3>Post 394</h3>
          <p class="muted">
            Supporting veterans through outreach, events, and service in the Palm Bay community.
          </p>
        </div>

        <div>
          <h3>Quick Links</h3>
          <ul class="muted" style="margin:0; padding-left:18px;">
            <li><a href="/events">Upcoming Events</a></li>
            <li><a href="/news">News & Announcements</a></li>
            <li><a href="/resources">Veteran Resources</a></li>
            <li><a href="/documents">Documents</a></li>
            <li><a href="/hall">Rent the Hall</a></li>
            <li><a href="/login">Staff Login</a></li>
          </ul>
        </div>

        <div>
          <h3>Contact</h3>
          <p class="muted">
            Address:
            <strong>
              <a
                href="https://www.google.com/maps/search/?api=1&query=396+Cogan+Dr,+Palm+Bay,+FL+32909"
                target="_blank"
                rel="noreferrer"
              >
                396 Cogan Dr, Palm Bay, FL 32909
              </a>
            </strong><br />
            Phone: <strong>(add phone)</strong><br />
            Email: <strong>info@alpb394.org</strong>
          </p>

          <div class="mapWrap">
            <iframe
              title="Post 394 Map"
              loading="lazy"
              referrerpolicy="no-referrer-when-downgrade"
              src="https://www.google.com/maps?q=396+Cogan+Dr,+Palm+Bay,+FL+32909&output=embed">
            </iframe>
          </div>

          <div style="margin-top:10px;">
            <a
              class="btn btn--primary btn--small"
              target="_blank"
              rel="noreferrer"
              href="https://www.google.com/maps/dir/?api=1&destination=396+Cogan+Dr,+Palm+Bay,+FL+32909">
              Get Directions
            </a>
          </div>
        </div>
      </div>

      <div class="container footer__bottom">
        <small class="muted">
          © {new Date().getFullYear()} American Legion Post 394. All rights reserved.
        </small>
      </div>
    </footer>
  </body>
</html>